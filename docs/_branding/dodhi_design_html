      <div class="kv-item"><div class="kv-label">Bg Image Offset Y</div><div class="kv-value">0 EMU</div></div>
      <div class="kv-item"><div class="kv-label">Body Space Before</div><div class="kv-value">20%</div></div>
      <div class="kv-item"><div class="kv-label">Kerning</div><div class="kv-value">12pt</div></div>
    </div>
  </section>

  <!-- GOVERNANCE -->
  <section id="governance" class="section">
    <div class="section-heading">
      <div class="slash">//</div>
      <h2>Governance</h2>
    </div>
    <div class="gov-grid">

      <div class="gov-card required">
        <div class="gov-title">Required Elements</div>
        <ul class="gov-list">
          <li>SERVCO wordmark must appear on every slide</li>
          <li>Diagonal blue line motif is a core brand signature — do not remove</li>
          <li>Wave illustration only on cover/section slides, not content slides</li>
          <li>Footer bar (two-tone) required on all content/body slides</li>
          <li>Slide numbers top-right in navy (#274291) on content slides</li>
        </ul>
      </div>

      <div class="gov-card color">
        <div class="gov-title">Color Rules</div>
        <ul class="gov-list">
          <li>Primary navy (#274291) is dominant — use for logo, headings, key UI elements</li>
          <li>Light blue (#1C92D1) is the accent — use sparingly for highlights, bars, icons</li>
          <li>Do not use accent colors (red, green, purple, orange) from the theme palette in brand presentations</li>
          <li>White text only on navy or blue backgrounds</li>
        </ul>
      </div>

      <div class="gov-card typo">
        <div class="gov-title">Typography Rules</div>
        <ul class="gov-list">
          <li>Montserrat ExtraBold for all headings and the wordmark</li>
          <li>Montserrat Medium for body copy</li>
          <li>Do not mix other fonts — Arial is bullet-point fallback only</li>
          <li>Titles left-aligned on content slides; centered on cover slides</li>
        </ul>
      </div>

      <div class="gov-card donot">
        <div class="gov-title">Do Not</div>
        <ul class="gov-list">
          <li>Do not add decorative elements that compete with the diagonal line motif</li>
          <li>Do not use the accent colors (red, green, orange) in corporate presentations</li>
          <li>Do not place the logo in the body content area</li>
          <li>Do not use the wave graphic on content/data slides</li>
        </ul>
      </div>

    </div>
  </section>

</main>

<script>
  function show(id, btn) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    btn.classList.add('active');
  }
</script>
