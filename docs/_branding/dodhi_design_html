<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SERVCO — Brand Parameters</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --navy:      #274291;
      --blue:      #3155A6;
      --light-blue:#1C92D1;
      --white:     #FFFFFF;
      --black:     #000000;
      --bg:        #F4F6FA;
      --surface:   #FFFFFF;
      --border:    #DDE3EF;
      --muted:     #8A97B8;
      --text:      #1A2340;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Montserrat', sans-serif;
      font-weight: 400;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--navy);
      position: relative;
      overflow: hidden;
      padding: 60px 64px 52px;
    }
    header::before {
      content: '';
      position: absolute;
      top: -40px; right: -60px;
      width: 2px; height: 200%;
      background: rgba(255,255,255,0.15);
      transform: rotate(-20deg);
      transform-origin: top right;
    }
    header::after {
      content: '//';
      position: absolute;
      right: 72px; top: 40px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 80px;
      color: var(--light-blue);
      opacity: 0.5;
      letter-spacing: -6px;
      line-height: 1;
    }
    .header-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--light-blue);
      margin-bottom: 16px;
    }
    header h1 {
      font-size: 52px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -1px;
      line-height: 1;
      margin-bottom: 10px;
    }
    header p {
      font-size: 14px;
      font-weight: 300;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.5px;
    }
    .footer-bar-preview {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 6px;
      display: flex;
    }
    .footer-bar-preview .fb-left  { flex: 3; background: var(--light-blue); }
    .footer-bar-preview .fb-right { flex: 1; background: var(--blue); }

    /* ── NAV TABS ── */
    nav {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 0;
      padding: 0 64px;
      overflow-x: auto;
    }
    nav button {
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      padding: 18px 22px 15px;
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--muted);
      cursor: pointer;
      white-space: nowrap;
      transition: color .2s, border-color .2s;
    }
    nav button:hover { color: var(--navy); }
    nav button.active { color: var(--navy); border-bottom-color: var(--light-blue); }

    /* ── LAYOUT ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 64px 80px;
    }
    .section { display: none; }
    .section.active { display: block; }

    /* ── SECTION HEADING ── */
    .section-heading {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 36px;
    }
    .section-heading h2 {
      font-size: 28px;
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.5px;
    }
    .section-heading .slash {
      font-size: 22px;
      font-weight: 800;
      color: var(--light-blue);
      letter-spacing: -2px;
    }

    /* ── CARDS ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 28px 32px;
      margin-bottom: 20px;
    }
    .card-title {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 18px;
    }

    /* ── COLORS ── */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 14px;
      margin-bottom: 20px;
    }
    .color-swatch {
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .swatch-block {
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    .swatch-block.light-text { color: rgba(255,255,255,0.9); }
    .swatch-block.dark-text  { color: rgba(0,0,0,0.45); border-bottom: 1px solid var(--border); }
    .swatch-info {
      padding: 10px 12px;
      background: #fff;
    }
    .swatch-name {
      font-size: 11px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 2px;
    }
    .swatch-role {
      font-size: 10px;
      color: var(--muted);
      line-height: 1.4;
    }
    .color-grid-theme {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
      gap: 10px;
    }
    .theme-swatch {
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .theme-swatch .swatch-block { height: 48px; font-size: 11px; }
    .theme-swatch .swatch-info { padding: 7px 9px; }
    .theme-swatch .swatch-name { font-size: 10px; }

    /* ── TYPOGRAPHY ── */
    .font-demo {
      padding: 28px 32px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      margin-bottom: 14px;
    }
    .font-demo-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .font-display {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 42px;
      color: var(--navy);
      letter-spacing: -1px;
      line-height: 1.1;
    }
    .font-body-display {
      font-family: 'Montserrat', sans-serif;
      font-weight: 500;
      font-size: 18px;
      color: var(--text);
      line-height: 1.6;
      margin-top: 6px;
    }
    .size-table { width: 100%; border-collapse: collapse; }
    .size-table th {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      text-align: left;
      padding: 0 0 12px;
      border-bottom: 1px solid var(--border);
    }
    .size-table td {
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .size-table tr:last-child td { border-bottom: none; }
    .size-name { font-size: 13px; font-weight: 500; color: var(--text); }
    .size-val  { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); }
    .size-preview {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      color: var(--navy);
      line-height: 1;
    }

    /* ── BULLET HIERARCHY ── */
    .bullet-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .bullet-row:last-child { border-bottom: none; }
    .bullet-level {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--muted);
      width: 50px;
      flex-shrink: 0;
    }
    .bullet-char {
      font-family: 'DM Mono', monospace;
      font-size: 16px;
      color: var(--navy);
      width: 28px;
      text-align: center;
      flex-shrink: 0;
    }
    .bullet-size {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      width: 50px;
      flex-shrink: 0;
    }
    .bullet-preview {
      font-family: 'Montserrat', sans-serif;
      font-weight: 500;
      color: var(--text);
    }

    /* ── LAYOUTS ── */
    .layout-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .layout-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--surface);
    }
    .layout-thumb {
      height: 100px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .layout-thumb.light { background: #F8FAFD; border-bottom: 1px solid var(--border); }
    .layout-thumb.dark  { background: var(--navy); }
    .layout-thumb-label {
      font-size: 11px;
      font-weight: 500;
      opacity: 0.5;
    }
    .layout-thumb.light .layout-thumb-label { color: var(--navy); }
    .layout-thumb.dark  .layout-thumb-label { color: #fff; }
    .layout-thumb-footer {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 10px;
      display: flex;
    }
    .layout-thumb-footer .fb-l { flex: 3; background: var(--light-blue); opacity: 0.8; }
    .layout-thumb-footer .fb-r { flex: 1; background: var(--navy); }
    .layout-info { padding: 14px 16px; }
    .layout-id   { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); margin-bottom: 4px; }
    .layout-name { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 10px; }
    .layout-chips { display: flex; flex-wrap: wrap; gap: 5px; }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 500;
      border: 1px solid var(--border);
      color: var(--text);
    }
    .chip-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .chip-size {
      background: #EEF2FB;
      border-color: #D5DDF5;
      color: var(--navy);
    }

    /* ── MOTIFS ── */
    .motif-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 700px) { .motif-grid { grid-template-columns: 1fr; } }
    .motif-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--surface);
    }
    .motif-preview {
      height: 120px;
      position: relative;
      overflow: hidden;
    }
    .motif-info { padding: 16px 18px; }
    .motif-name { font-size: 13px; font-weight: 500; color: var(--navy); margin-bottom: 6px; }
    .motif-desc { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 10px; }
    .motif-applies {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--light-blue);
    }

    /* Motif previews */
    .mp-diagonal {
      background: #F0F4FA;
    }
    .mp-diagonal::before {
      content: '';
      position: absolute;
      top: -20px; right: 30px;
      width: 1px; height: 200%;
      background: var(--blue);
      opacity: 0.35;
      transform: rotate(-20deg);
    }
    .mp-slash {
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mp-slash span {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 64px;
      letter-spacing: -6px;
      line-height: 1;
    }
    .mp-slash .s1 { color: var(--light-blue); }
    .mp-slash .s2 { color: #fff; }
    .mp-wave {
      background: var(--navy);
      display: flex;
      align-items: flex-end;
    }
    .mp-wave svg { width: 100%; height: 80px; }
    .mp-footer {
      background: #F8FAFD;
      display: flex;
      align-items: flex-end;
    }
    .mp-footer-bar {
      width: 100%;
      height: 32px;
      display: flex;
    }
    .mp-footer-bar .fl {
      flex: 3;
      background: var(--light-blue);
      display: flex;
      align-items: center;
      padding-left: 12px;
      gap: 3px;
    }
    .mp-footer-bar .fl span {
      display: inline-block;
      width: 1px; height: 14px;
      background: rgba(255,255,255,0.4);
      transform: skewX(-20deg);
    }
    .mp-footer-bar .fr {
      flex: 1;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mp-footer-bar .fr span {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 9px;
      color: #fff;
      letter-spacing: 1px;
    }
    .mp-hline {
      background: #F0F4FA;
    }
    .mp-hline::after {
      content: '';
      position: absolute;
      bottom: 28px; left: 0; right: 0;
      height: 1.5px;
      background: var(--light-blue);
      opacity: 0.6;
    }

    /* ── SLIDE ANATOMY ── */
    .anatomy-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }
    @media (max-width: 750px) { .anatomy-grid { grid-template-columns: 1fr; } }
    .anatomy-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .anatomy-slide {
      height: 130px;
      position: relative;
      overflow: hidden;
    }
    .anat-light { background: #fff; border-bottom: 1px solid var(--border); }
    .anat-dark  { background: var(--navy); }
    .anat-content { background: #fff; border-bottom: 1px solid var(--border); }

    .anat-logo {
      position: absolute;
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 10px;
      letter-spacing: 0.5px;
    }
    .anat-logo.navy  { color: var(--navy); top: 12px; left: 14px; }
    .anat-logo.white { color: #fff; bottom: 34px; left: 14px; }
    .anat-logo.footer-right {
      color: #fff;
      bottom: 4px; right: 0;
      background: var(--navy);
      padding: 4px 8px;
      font-size: 8px;
    }
    .anat-diag {
      position: absolute;
      top: -10px; right: 20px;
      width: 1px; height: 160%;
      background: var(--blue);
      opacity: 0.2;
      transform: rotate(-20deg);
    }
    .anat-slash {
      position: absolute;
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 20px;
      letter-spacing: -2px;
      top: 20px; right: 24px;
    }
    .anat-slash.color { color: var(--light-blue); }
    .anat-slash.white { color: #fff; opacity: 0.7; }
    .anat-rule {
      position: absolute;
      bottom: 22px; left: 0; right: 0;
      height: 1px;
      background: var(--light-blue);
      opacity: 0.5;
    }
    .anat-rule.white-rule { background: #fff; opacity: 0.4; }
    .anat-footer-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 14px;
      display: flex;
    }
    .anat-footer-bar .fl { flex: 3; background: var(--light-blue); }
    .anat-footer-bar .fr { flex: 1; background: var(--navy); }
    .anat-slidenum {
      position: absolute;
      top: 8px; right: 10px;
      font-family: 'DM Mono', monospace;
      font-size: 8px;
      color: var(--navy);
    }
    .anat-bottom-band {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 22px;
      background: var(--light-blue);
    }
    .anatomy-info { padding: 14px 16px; }
    .anatomy-name { font-size: 13px; font-weight: 500; color: var(--navy); margin-bottom: 10px; }
    .anatomy-props { display: flex; flex-direction: column; gap: 5px; }
    .anatomy-prop {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
    }
    .anatomy-prop-key { color: var(--muted); }
    .anatomy-prop-val { font-weight: 500; color: var(--text); }
    .badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 10px;
      font-size: 10px;
      font-weight: 500;
    }
    .badge-yes  { background: #E6F4EA; color: #2D7A45; }
    .badge-no   { background: #F3F4F6; color: var(--muted); }

    /* ── GOVERNANCE ── */
    .gov-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 700px) { .gov-grid { grid-template-columns: 1fr; } }
    .gov-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 22px 24px;
      background: var(--surface);
    }
    .gov-card.required { border-top: 3px solid var(--navy); }
    .gov-card.color    { border-top: 3px solid var(--light-blue); }
    .gov-card.typo     { border-top: 3px solid var(--blue); }
    .gov-card.donot    { border-top: 3px solid #C0504D; }
    .gov-title { font-size: 11px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
    .gov-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .gov-list li {
      font-size: 12px;
      color: var(--text);
      line-height: 1.5;
      padding-left: 16px;
      position: relative;
    }
    .gov-list li::before {
      content: '';
      position: absolute;
      left: 0; top: 7px;
      width: 5px; height: 5px;
      border-radius: 50%;
    }
    .gov-card.required li::before { background: var(--navy); }
    .gov-card.color    li::before { background: var(--light-blue); }
    .gov-card.typo     li::before { background: var(--blue); }
    .gov-card.donot    li::before { background: #C0504D; }

    /* ── CANVAS ── */
    .kv-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 14px;
    }
    .kv-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px 18px;
    }
    .kv-label { font-size: 10px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
    .kv-value { font-family: 'DM Mono', monospace; font-size: 14px; color: var(--navy); font-weight: 500; }
  </style>
</head>
<body>

<header>
  <div class="header-label">Brand Parameters · v1.0</div>
  <h1>SERVCO</h1>
  <p>SERVCO_CORP_PRES_WIDE — Extracted from Servco_Theme.pptx</p>
  <div class="footer-bar-preview">
    <div class="fb-left"></div>
    <div class="fb-right"></div>
  </div>
</header>

<nav>
  <button class="active" onclick="show('colors', this)">Colors</button>
  <button onclick="show('typography', this)">Typography</button>
  <button onclick="show('layouts', this)">Layouts</button>
  <button onclick="show('motifs', this)">Visual Motifs</button>
  <button onclick="show('anatomy', this)">Slide Anatomy</button>
  <button onclick="show('canvas', this)">Canvas</button>
  <button onclick="show('governance', this)">Governance</button>
</nav>

<main>

  <!-- COLORS -->
  <section id="colors" class="section active">
    <div class="section-heading">
      <div class="slash">//</div>
      <h2>Color System</h2>
    </div>

    <div class="card">
      <div class="card-title">Core Brand Colors</div>
      <div class="color-grid">
        <div class="color-swatch">
          <div class="swatch-block light-text" style="background:#274291">#274291</div>
          <div class="swatch-info">
            <div class="swatch-name">Primary Navy</div>
            <div class="swatch-role">Logo, headings, footer lockup, slide number</div>
          </div>
        </div>
        <div class="color-swatch">
          <div class="swatch-block light-text" style="background:#3155A6">#3155A6</div>
          <div class="swatch-info">
            <div class="swatch-name">Primary Blue</div>
            <div class="swatch-role">Diagonal line motif, decorative elements, footer left</div>
          </div>
        </div>
        <div class="color-swatch">
          <div class="swatch-block light-text" style="background:#1C92D1">#1C92D1</div>
          <div class="swatch-info">
            <div class="swatch-name">Accent Light Blue</div>
            <div class="swatch-role">Accent bars, slash icon, wave tones, body accent</div>
          </div>
        </div>
        <div class="color-swatch">
          <div class="swatch-block dark-text" style="background:#FFFFFF">#FFFFFF</div>
          <div class="swatch-info">
            <div class="swatch-name">White</div>
            <div class="swatch-role">Text on dark backgrounds, logo on dark slides</div>
          </div>
        </div>
        <div class="color-swatch">
          <div class="swatch-block light-text" style="background:#000000">#000000</div>
          <div class="swatch-info">
            <div class="swatch-name">Black</div>
            <div class="swatch-role">Body text on light backgrounds</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Office Theme Palette (reference only — not for use in brand decks)</div>
      <div class="color-grid-theme">
        <div class="theme-swatch">
          <div class="swatch-block light-text" style="background:#000000">#000000</div>
          <div class="swatch-info"><div class="swatch-name">Dark 1</div></div>
        </div>
        <div class="theme-swatch">
          <div class="swatch-block dark-text" style="background:#FFFFFF">#FFFFFF</div>
          <div class="swatch-info"><div class="swatch-name">Light 1</div></div>
